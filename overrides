
{% extends "base.html" %}

{% block content %}
  {{ super() }}
{% endblock %}

{% block scripts %}
  {{ super() }}
  <script>
    var FLY_GIFS = [
      'https://media2.giphy.com/media/v1.Y2lkPTc5MGI3NjExb3Btc3FseWdtNmhueTl0Ym5xcnN6dzI0NWxpaXJmbWk1YWt4NXc4dCZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9cw/TucOQxQkfvRhY3TiwT/giphy.gif',
      'https://media4.giphy.com/media/v1.Y2lkPTc5MGI3NjExYTk2OThsY2JpcTlkdDZvdHdnbzY0ODg4NmlwMzFjZW9ydXR6amxqdiZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9cw/cQmpHM5Rh64iGDQB75/giphy.gif',
      'https://media1.giphy.com/media/v1.Y2lkPTc5MGI3NjExbzB2aHl5M3ZpNDJrZGZyYWJndW44ajc3aHVqaTI5bnI2ODAwcmp1YiZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9cw/2l8BqseoXKPUQMjezi/giphy.gif',
      'https://media1.giphy.com/media/v1.Y2lkPTc5MGI3NjExcTl6Y3FicmNqMDZ3Znp0Mm01MnJ3OXRlb3g5emh5MTN1ZTZkdzVqZyZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9cw/UpxdwjZ5kXyJcTnbq0/giphy.gif',
      'https://media0.giphy.com/media/v1.Y2lkPTc5MGI3NjExZzNubXN1YXgzeDE4d2tuZ3J0eXl5enkwZjNtNHg1cjVhdmtmZjJsdCZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9cw/HLZuyghzXHvbAvUSwr/giphy.gif',
      'https://media3.giphy.com/media/KOrIxsEQaBJcHgiiqL/giphy.gif'
    ];

    FLY_GIFS.forEach(function(u){ new Image().src = u; });

    var FLY_MAX = 3;
    var _flyCount = 0;

    function triggerFlyGif(){
      if(_flyCount >= FLY_MAX) return;
      _flyCount++;
      var gif    = FLY_GIFS[Math.floor(Math.random() * FLY_GIFS.length)];
      var topPct = (5 + Math.random() * 85) + '%';
      var dur    = (2.5 + Math.random() * 5).toFixed(1) + 's';
      var size   = (100 + Math.random() * 180) + 'px';
      var el = document.createElement('img');
      el.src = gif;
      var startTop = parseFloat(topPct);
      el.style.cssText = 'position:fixed;right:-200px;top:'+topPct+';width:'+size+';height:auto;z-index:500;pointer-events:all;cursor:grab;border:none;outline:none;box-shadow:none;background:transparent;';
      document.body.appendChild(el);
      var _durMs = parseFloat(dur) * 1000;
      var _startTime = Date.now();
      var _waveAmp = 8 + Math.random() * 12;
      var _waveFreq = 1.5 + Math.random() * 2;
      var _flyRaf = null;
      var _dragging = false;
      function animateFly(){
        if(_dragging){ _flyRaf = requestAnimationFrame(animateFly); return; }
        var elapsed = Date.now() - _startTime;
        var progress = elapsed / _durMs;
        if(progress >= 1){ if(el.parentNode){el.parentNode.removeChild(el); _flyCount--;} return; }
        var x = (1 - progress) * (window.innerWidth + 200) - 200;
        el.style.right = 'auto';
        el.style.left = x + 'px';
        var topVal = startTop + Math.sin(progress * Math.PI * 2 * _waveFreq) * _waveAmp;
        el.style.top = topVal + '%';
        _flyRaf = requestAnimationFrame(animateFly);
      }
      el.onmousedown = function(){ _dragging = true; };
      el.onmouseup = function(){ _dragging = false; };
      el.onmouseleave = function(){ _dragging = false; };
      animateFly();
    }

    function scheduleFlyGif(){
      var delay = (30 + Math.random() * 60) * 1000;
      setTimeout(function(){
        triggerFlyGif();
        if(!/Mobi|Android|iPhone|iPad/i.test(navigator.userAgent) && window.innerWidth >= 1024) scheduleFlyGif();
      }, delay);
    }

    if(!/Mobi|Android|iPhone|iPad/i.test(navigator.userAgent) && window.innerWidth >= 1024){
      scheduleFlyGif();
    }
  </script>
{% endblock %}
